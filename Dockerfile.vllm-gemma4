# =============================================================================
# Dockerfile.vllm-gemma4 — vLLM image with Transformers v5.5.3+ for Gemma 4
# =============================================================================
# Both gemma4-cu130 and cu130-nightly ship with old transformers that
# predates gemma4 architecture registration.
#
# vLLM packages live at /usr/local/lib/python3.12/dist-packages/ but the
# python3.12 binary location varies between images (not always on PATH as
# 'python3.12'). We use `find` to locate it reliably.
#
# Build:
#   make build-gemma4
#   # or directly:
#   docker build --no-cache -f Dockerfile.vllm-gemma4 -t vllm/vllm-openai:gemma4-v2 .
# =============================================================================

FROM vllm/vllm-openai:cu130-nightly

# Debug: show what Python interpreters and pip binaries exist, then
# upgrade transformers directly into the site-packages dir vLLM uses.
# We know from container tracebacks that vLLM lives at:
#   /usr/local/lib/python3.12/dist-packages/
# So we install there directly using pip's --target flag, which
# bypasses any interpreter PATH confusion entirely.
RUN echo "=== Python binaries ===" \
    && find / -name "python3*" -type f -executable 2>/dev/null \
    && echo "=== pip binaries ===" \
    && find / -name "pip*" -type f -executable 2>/dev/null \
    && echo "=== Installing transformers from git ===" \
    && pip install --no-cache-dir --upgrade --target /usr/local/lib/python3.12/dist-packages/ git+https://github.com/huggingface/transformers.git \
    && echo "=== Verify ===" \
    && PYTHONPATH=/usr/local/lib/python3.12/dist-packages python3 -c "import transformers; print('transformers', transformers.__version__)"
