# =============================================================================
# Dockerfile.vllm-gemma4 — vLLM image with Transformers v5.5.3+ for Gemma 4
# =============================================================================
# Both gemma4-cu130 and cu130-nightly ship with old transformers that
# predates gemma4 architecture registration.
#
# vLLM packages live at /usr/local/lib/python3.12/dist-packages/ but the
# python3.12 binary location varies between images (not always on PATH as
# 'python3.12'). We use `find` to locate it reliably.
#
# Build:
#   make build-gemma4
#   # or directly:
#   docker build --no-cache -f Dockerfile.vllm-gemma4 -t vllm/vllm-openai:gemma4-v2 .
# =============================================================================

FROM vllm/vllm-openai:cu130-nightly

# Locate the python3.12 binary that owns vLLM's site-packages and upgrade
# transformers there. Running as root in Docker, pip installs to
# /usr/local/lib/python3.12/dist-packages/ — the same prefix as vLLM.
RUN PYTHON=$(find /usr -name "python3.12" -type f -executable 2>/dev/null | head -1) \
    && [ -n "$PYTHON" ] || { echo "ERROR: python3.12 not found under /usr"; exit 1; } \
    && echo "Using Python: $PYTHON" \
    && "$PYTHON" -m pip install --no-cache-dir --upgrade "transformers>=5.5.3" \
    && "$PYTHON" -c "import transformers; print('transformers', transformers.__version__)"
