# =============================================================================
# Dockerfile.vllm-gemma4 — vLLM image with Transformers v5.5.3+ for Gemma 4
# =============================================================================
# The stock vllm/vllm-openai:gemma4-cu130 image bundles vLLM 0.18.2rc1 with
# an outdated transformers that predates the `gemma4` architecture.
#
# vLLM v0.19.1 (released 2026-04-17) ships Transformers v5.5.3 with full
# Gemma 4 support. The cu130-nightly image is kept current and as of
# 2026-04-23 is at v0.19.1+ with all Gemma4 fixes:
#   - Transformers v5.5.3 (gemma4 architecture registration)
#   - Streaming tool call fixes
#   - Quantized MoE support
#   - Token repetition fix
#
# Build:
#   make build-gemma4
#   # or directly:
#   docker build -f Dockerfile.vllm-gemma4 -t vllm/vllm-openai:gemma4-v2 .
# =============================================================================

FROM vllm/vllm-openai:cu130-nightly
