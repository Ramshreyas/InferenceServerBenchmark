# =============================================================================
# Dockerfile.vllm-gemma4 — vLLM image with Transformers v5.5.3+ for Gemma 4
# =============================================================================
# Both gemma4-cu130 and cu130-nightly ship with an old transformers that
# predates gemma4 architecture registration.
#
# vLLM installs into /usr/local/lib/python3.12/dist-packages/, so we must
# upgrade transformers via the explicit /usr/local/bin/python3.12 binary to
# ensure we hit the correct site-packages (not any other python on PATH).
#
# Build:
#   make build-gemma4
#   # or directly:
#   docker build -f Dockerfile.vllm-gemma4 -t vllm/vllm-openai:gemma4-v2 .
# =============================================================================

FROM vllm/vllm-openai:cu130-nightly

# Upgrade transformers in the exact python3.12 environment vLLM uses.
# /usr/local/lib/python3.12/dist-packages/ is where vLLM lives — this
# targets that interpreter explicitly.
RUN /usr/local/bin/python3.12 -m pip install --no-cache-dir --upgrade "transformers>=5.5.3" \
    && /usr/local/bin/python3.12 -c "import transformers; print('transformers', transformers.__version__)"
