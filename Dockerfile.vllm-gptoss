# =============================================================================
# Dockerfile.vllm-gptoss — vLLM image with native MXFP4 support for gpt-oss
# =============================================================================
# The stock vllm/vllm-openai nightly does NOT include the gpt-oss-specific
# MXFP4 kernels.  Without them, vLLM falls back to Marlin FP4→FP16 dequant
# which wastes ~6 GB VRAM and loses the throughput benefit of native FP4
# tensor-core ops.
#
# The original cookbook (https://developers.openai.com/cookbook/articles/gpt-oss/run-vllm)
# pinned torch==2.9.0.dev20250804+cu128 which has been rotated off PyTorch's
# nightly index (openai/openai-cookbook#2330).  The community-verified fix
# (openai/openai-cookbook#2334, #2330) is:
#   1. Install STABLE torch 2.9.0+cu128 via direct wheel URL
#   2. Install vllm from gpt-oss wheels with --index-strategy unsafe-best-match
#
# Build:
#   docker build -f Dockerfile.vllm-gptoss -t vllm-gptoss:latest .
# =============================================================================

FROM nvidia/cuda:12.8.0-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# System deps + Python 3.12 from deadsnakes (not in Jammy default repos)
RUN apt-get update && apt-get install -y --no-install-recommends \
        software-properties-common \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
        python3.12 python3.12-venv python3.12-dev \
        curl git build-essential \
        libsndfile1 libsox-fmt-all \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1

# Install uv — the package manager OpenAI recommends for this install
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Create venv
RUN uv venv /opt/vllm-env --python 3.12 --seed
ENV VIRTUAL_ENV=/opt/vllm-env
ENV PATH="/opt/vllm-env/bin:$PATH"

# Step 1: Install STABLE PyTorch 2.9.0+cu128 via direct wheel URL.
# The gpt-oss vllm wheel pins torch==2.9.0.dev20250804+cu128 (expired nightly),
# but stable 2.9.0+cu128 is ABI-compatible and verified by the community
# (openai/openai-cookbook#2330).
RUN uv pip install \
        "https://download.pytorch.org/whl/cu128/torch-2.9.0%2Bcu128-cp312-cp312-manylinux_2_28_x86_64.whl"

# Step 2: Install vLLM from gpt-oss wheels.
# --pre allows pre-release versions, --index-strategy unsafe-best-match lets
# uv accept the already-installed stable torch as satisfying the pinned dep.
RUN uv pip install --pre vllm \
        --extra-index-url https://wheels.vllm.ai/gpt-oss/ \
        --index-strategy unsafe-best-match

# Audio processing libs (shared with stock entrypoint)
RUN uv pip install soxr librosa soundfile 'mistral-common[audio]'

# Upgrade transformers (consistency with entrypoint.sh)
RUN uv pip install --upgrade transformers

# Copy the entrypoint wrapper (same as stock, delegates to `vllm serve`)
COPY scripts/vllm-entrypoint.sh /usr/local/bin/vllm-entrypoint.sh
RUN chmod +x /usr/local/bin/vllm-entrypoint.sh

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/vllm-entrypoint.sh"]
